<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuizVK</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: bold; }
        .card { border-radius: 15px; transition: transform 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; }
        .btn-primary:hover { background: linear-gradient(135deg, #5a67d8 0%, #6a3d99 100%); transform: scale(1.02); }
        .btn-success { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border: none; }
        .btn-info { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border: none; color: white; }
        footer { margin-top: 50px; padding: 20px 0; background: white; border-top: 1px solid #dee2e6; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="container">
            <a class="navbar-brand" href="/">🎯 QuizVK</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (Context.Session.GetString("Username") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/">Главная</a>
                        </li>
                        @if (Context.Session.GetString("Role") == "Organizer")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Quiz/Create">Создать квиз</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Quiz/MyQuizzes">Мои квизы</a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (Context.Session.GetString("Username") != null)
                    {
                        <li class="nav-item">
                            <span class="navbar-text me-3 text-white">👋 @Context.Session.GetString("Username")</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Logout">Выйти</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">Вход</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Register">Регистрация</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container text-center text-muted">
            <small>QuizVK © @DateTime.Now.Year - Все права защищены</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>