@using QuizMvp.Models
@model Session

@{
    ViewData["Title"] = "Подключение к квизу";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg">
                <div class="card-body text-center p-5">
                    <h1 class="display-1 mb-3">🎯</h1>
                    <h3>Присоединение к квизу</h3>
                    <h4 class="text-muted">@Model.Quiz.Title</h4>
                    <p class="text-muted">Код комнаты: <strong>@Model.JoinCode</strong></p>
                    
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Ожидайте начала квиза
                    </div>
                    
                    <div id="statusContainer">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Загрузка...</span>
                        </div>
                        <p class="mt-2">Подключение к комнате...</p>
                    </div>
                    
                    <div id="questionContainer" style="display: none;">
                      
                    </div>
                    
                    <div id="resultContainer" style="display: none;">
                       
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/quizHub")
        .build();

        const roomCode = '@Model.JoinCode';
        const sessionId = @Model.Id;
        let currentQuestionIndex = 0;
        let totalQuestions = @Model.Quiz.Questions.Count;

        connection.start().then(function () {

        connection.invoke("JoinRoom", roomCode, "Участник")
        .catch(function (err) {
        console.error(err);
        });
                
        document.getElementById('statusContainer').innerHTML =
        '<div class="alert alert-success">Вы подключены! Ожидайте начала квиза.</div>';
        }).catch(function (err) {
        console.error(err);
        document.getElementById('statusContainer').innerHTML =
        '<div class="alert alert-danger">❌ Ошибка подключения</div>';
        });

        connection.on("QuizStarted", function (sessionId) {
        document.getElementById('statusContainer').innerHTML =
        '<div class="alert alert-success"> Квиз начался!</div>';
        loadQuestion(0);
        });

        connection.on("ShowQuestion", function (questionIndex, total) {
        loadQuestion(questionIndex);
        currentQuestionIndex = questionIndex;
        totalQuestions = total;
        });

        connection.on("QuizEnded", function () {
        document.getElementById('questionContainer').style.display = 'none';
        document.getElementById('resultContainer').style.display = 'block';
        document.getElementById('resultContainer').innerHTML =
        '<div class="alert alert-success">Квиз завершен! Спасибо за участие.</div>';
        loadLeaderboard();
        });

        connection.on("AnswerSubmitted", function (userId, questionId) {

        });

        function loadQuestion(index) {
        fetch(`/Quiz/GetQuestion?sessionId=${sessionId}&questionIndex=${index}`)
        .then(response => response.json())
        .then(data => {
        showQuestion(data);
        })
        .catch(error => {
        console.error('Error loading question:', error);
        });
        }

        function showQuestion(question) {
        const container = document.getElementById('questionContainer');
        container.style.display = 'block';
            
        const optionsHtml = question.options.map(opt => `
        <div class="form-check mb-2">
        <input class="form-check-input" type="${question.isMultiple ? 'checkbox' : 'radio'}"
        name="question_${question.id}" value="${opt.id}" id="opt_${opt.id}" />
        <label class="form-check-label" for="opt_${opt.id}">
        ${opt.imageUrl ? `<img src="${opt.imageUrl}" style="max-height: 30px;" class="me-2" />` : ''}
        ${opt.text}
        </label>
        </div>
        `).join('');
            
        container.innerHTML = `
        <div class="card mt-4">
        <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
        <h5>Вопрос ${question.index + 1}/${question.total}</h5>
        <span class="badge bg-primary">${question.points} баллов</span>
        </div>
        <p class="mt-3">${question.text}</p>
        ${question.imageUrl ? `<img src="${question.imageUrl}" class="img-fluid mb-3" style="max-height: 200px;" />` : ''}
        <div id="optionsContainer">
        ${optionsHtml}
        </div>
        <button class="btn btn-primary mt-3" onclick="submitAnswer(${question.id})">Ответить</button>
        </div>
        </div>
        `;
        }

        function submitAnswer(questionId) {
        const selected = [];
        document.querySelectorAll(`input[name="question_${questionId}"]:checked`).forEach(el => {
        selected.push(parseInt(el.value));
        });

        if (selected.length === 0) {
        alert('Выберите вариант ответа!');
        return;
        }

        fetch('/Quiz/SubmitAnswer', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json'
        },
        body: JSON.stringify({
        sessionId: sessionId,
        questionId: questionId,
        selectedOptionIds: selected
        })
        })
        .then(response => response.json())
        .then(data => {
        if (data.isCorrect) {
        document.getElementById('questionContainer').innerHTML =
        `<div class="alert alert-success mt-3">Правильно! +${data.points} баллов</div>
        <button class="btn btn-primary mt-2" onclick="nextQuestion()">Следующий вопрос →</button>`;
        } else {
        document.getElementById('questionContainer').innerHTML =
        `<div class="alert alert-danger mt-3">Неправильно</div>
        <button class="btn btn-primary mt-2" onclick="nextQuestion()">Следующий вопрос →</button>`;
        }
        })
        .catch(error => {
        console.error('Error submitting answer:', error);
        alert('Ошибка при отправке ответа');
        });
        }

        function nextQuestion() {
        if (currentQuestionIndex + 1 < totalQuestions) {
        connection.invoke("NextQuestion", roomCode, currentQuestionIndex + 1, totalQuestions);
        } else {
        connection.invoke("EndQuiz", roomCode);
        }
        }

        function loadLeaderboard() {
        fetch(`/Quiz/GetLeaderboard?sessionId=${sessionId}`)
        .then(response => response.json())
        .then(data => {
        let html = '<h4 class="mt-3">🏆 Таблица лидеров</h4><ul class="list-group">';
        if (data.length === 0) {
        html += '<li class="list-group-item text-center">Нет данных</li>';
        } else {
        data.forEach((item, index) => {
        const medal = index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : `${index+1}.`;
        html += `<li class="list-group-item d-flex justify-content-between align-items-center">
        ${medal} ${item.username}
        <span class="badge bg-primary rounded-pill">${item.totalScore} баллов</span>
        </li>`;
        });
        }
        html += '</ul>';
        document.getElementById('resultContainer').innerHTML = html;
        document.getElementById('resultContainer').style.display = 'block';
        })
        .catch(error => {
        console.error('Error loading leaderboard:', error);
        });
        }
        
        window.addEventListener('beforeunload', function() {
        connection.invoke("LeaveRoom", roomCode);
        });
    </script>
}